		},
		"userdoc": {
			"events": {
				"NodeChanged(uint8,address,address)": {
					"notice": "Emitted when a node rotates its address. Records the node index, the old address that initiated the change, and the new address that replaces it."
				},
				"RequestConfirmed(address,address,uint256,uint256)": {
					"notice": "Emitted each time a node submits its confirmation for a given nonce. Off-chain services can track this to monitor consensus progress."
				},
				"TransferExecuted(address,uint256,uint256)": {
					"notice": "Emitted once consensus is reached and Bridge_sol.Transfer() has been called."
				}
			},
			"kind": "user",
			"methods": {
				"bridgeContract()": {
					"notice": "Address of the Bridge_sol contract that holds the USDC funds and executes the token transfer once consensus is reached."
				},
				"changeNode1(address)": {
					"notice": "Each node can rotate only its own registered address. Designed for key rotation or node infrastructure changes without requiring a full contract redeployment."
				},
				"confirmRequest(address,uint256,uint256)": {
					"notice": "Called by each node after it detects a Request_Approved event on the source chain. Each node submits the recipient address, amount, and nonce it observed. After each submission the contract checks whether any two nodes agree — if yes, transfer_made is set to true and Bridge_sol.Transfer() is called. The transfer_made flag permanently blocks re-execution for that nonce."
				},
				"federation_node_1()": {
					"notice": "Addresses of the three federation nodes. Only these addresses are allowed to confirm requests and rotate their own address."
				},
				"requests(uint256)": {
					"notice": "Maps each nonce to its confirmation data. Allows independent lookups per request without array iteration."
				}
			},
			"version": 1
		}
