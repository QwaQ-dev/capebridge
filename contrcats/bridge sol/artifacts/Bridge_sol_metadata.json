		"devdoc": {
			"author": "no-hive",
			"kind": "dev",
			"methods": {},
			"title": "Simple USDC Stacks-Base Bridge",
			"version": 1
		},
		"userdoc": {
			"events": {
				"Request_Approved(address,uint256,string,uint256)": {
					"notice": "Emitted by BridgeRequest to notify off-chain federation nodes that a user has deposited funds and a cross-chain transfer should begin. Nodes listen for this event and call confirmRequest() on FederationSync."
				}
			},
			"kind": "user",
			"methods": {
				"Deposit(uint256,string)": {
					"notice": "Entry point for users who want to bridge tokens to the other chain. Pulls USDC from the caller's wallet into this contract, then triggers BridgeRequest to update balances and notify the nodes."
				},
				"Transfer(address,uint256)": {
					"notice": "Called exclusively by the FederationSync multisig contract after 2-of-3 nodes reach consensus on a cross-chain transfer. Sends USDC from this contract's balance to the recipient on this chain."
				},
				"multisig_contract()": {
					"notice": "Address of the FederationSync multisig contract. Only this address is authorized to call Transfer()."
				},
				"nonce()": {
					"notice": "Incremented on each Deposit to uniquely identify every bridge request. Off-chain nodes use this nonce to match events across chains."
				},
				"own_balance()": {
					"notice": "Tracks the USDC balance held on this chain (own_balance) and the mirrored balance available on the other chain (external_balance). start_balance is recorded at deployment for accounting reference."
				},
				"token()": {
					"notice": "Address of the USDC ERC-20 token contract on this chain."
				}
			},
			"notice": "This contract is for testing purposes only.         Production version must use SafeERC20.",
			"version": 1
		}
